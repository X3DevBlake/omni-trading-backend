# ── Server ─────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ───────────────────────────
# Postgres (production — use a managed DB like Neon, Supabase, or Railway)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omni?schema=public"

# For local development without Postgres, you can switch schema.prisma to
# provider = "sqlite" and use:
# DATABASE_URL="file:./dev.db"

# ── Auth ───────────────────────────────
# Generate with:   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_48_BYTES_OF_RANDOMNESS_REQUIRED"

# ── CORS ───────────────────────────────
# Comma-separated list of origins the frontend may call from
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"
